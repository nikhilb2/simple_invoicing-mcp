{
  "name": "simple_invoicing-mcp",
  "version": "1.0.0",
  "description": "MCP server for simple_invoicing API — bridge to any deployed simple_invoicing FastAPI instance",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "simple-invoicing-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "invoicing",
    "fastapi",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.2",
    "axios": "^1.7.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.21",
    "axios-mock-adapter": "^2.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
